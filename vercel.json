{
    "version": 2,
    "framework": null,
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "build": {
        "env": {
            "APP_ENV": "production",
            "APP_DEBUG": "true",
            "VERCEL": "1"
        }
    },
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false"
    },
    "routes": [
        {
            "src": "/assets/(.*)",
            "dest": "/public/assets/$1"
        },
        {
            "src": "/downloads/(.*)",
            "dest": "/public/downloads/$1"
        },
        {
            "src": "/storage/(.*)",
            "dest": "/public/storage/$1"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/manifest.json",
            "dest": "/public/manifest.json"
        },
        {
            "src": "/sw.js",
            "dest": "/public/sw.js"
        },
        {
            "src": "/robots.txt",
            "dest": "/public/robots.txt"
        },
        {
            "src": "/(.*)\\.apk",
            "dest": "/public/$1.apk"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
