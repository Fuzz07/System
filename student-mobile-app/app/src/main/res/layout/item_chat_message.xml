<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="12dp">

    <!-- Bot Message Layout -->
    <LinearLayout
        android:id="@+id/layoutBot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:visibility="visible">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_dialog_info"
            android:tint="@color/indigo_600"
            android:background="#1A4F46E5"
            android:padding="4dp"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="64dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E2E8F0"
            app:cardBackgroundColor="@color/white">

            <TextView
                android:id="@+id/textBotMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="14dp"
                android:paddingTop="10dp"
                android:paddingRight="14dp"
                android:paddingBottom="10dp"
                android:textSize="14.5sp"
                android:textColor="@color/slate_800"
                android:lineSpacingExtra="3dp"
                android:text="Bot reply goes here..." />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- User Message Layout -->
    <RelativeLayout
        android:id="@+id/layoutUser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_marginStart="64dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/indigo_600">

            <TextView
                android:id="@+id/textUserMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="14dp"
                android:paddingTop="10dp"
                android:paddingRight="14dp"
                android:paddingBottom="10dp"
                android:textSize="14.5sp"
                android:textColor="@color/white"
                android:lineSpacingExtra="3dp"
                android:text="User message goes here..." />

        </com.google.android.material.card.MaterialCardView>

    </RelativeLayout>

</LinearLayout>